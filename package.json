{
  "name": "pats-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/css-guardrails.mjs && node scripts/setup-uploads.mjs && next dev",
    "build": "node scripts/css-guardrails.mjs && node scripts/setup-uploads.mjs && node scripts/prisma-generate-safe.mjs && next build",
    "postinstall": "node scripts/setup-uploads.mjs && prisma generate",
    "start": "node scripts/setup-uploads.mjs && next start",
    "lint": "node scripts/css-guardrails.mjs && next lint",
    "guardrails": "node scripts/css-guardrails.mjs",
    "guardrails:update": "node scripts/css-guardrails.mjs --update-baseline",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:awards": "npx tsx prisma/seed-awards.ts",
    "db:seed:hero": "npx tsx prisma/seed-hero.ts",
    "migrate:payment-proofs": "node scripts/migrate-payment-proofs-to-storage.mjs",
    "repair:pdfs": "node scripts/repair-news-pdf-paths.mjs",
    "media:process": "python scripts/process-pats-media.py",
    "awards:split": "node scripts/split-awards.js",
    "awards:crop-display": "node scripts/crop-award-display.js",
    "audit:check": "node scripts/audit-check.mjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "15.5.18",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
