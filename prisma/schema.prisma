generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String              @id @default(cuid())
  email                    String              @unique
  passwordHash             String
  emailVerifiedAt          DateTime?           @default(now())
  firstName                String
  lastName                 String
  rank                     String
  gender                   String
  country                  String?
  nationality              String?             @default("Pakistani")
  role                     String              @default("user")
  approved                 Boolean             @default(false)
  applicationStatus        String              @default("PENDING")
  paymentStatus            String              @default("PENDING")
  adminNotes               String?             @db.Text
  rejectionReason          String?             @db.Text
  rejectedAt               DateTime?
  approvedAt               DateTime?
  suspended                Boolean             @default(false)
  failedLoginAttempts      Int                 @default(0)
  lockedUntil              DateTime?
  privacyAccepted          Boolean             @default(false)
  privacyAcceptedAt        DateTime?
  /**
   * Participation confirmation (first-login availability dialog).
   */
  participationConfirmedAt DateTime?
  participationDeclinedAt  DateTime?
  /**
   * Team registration workflow.
   */
  teamRegisteredAt         DateTime?
  rosterCompletedAt        DateTime?
  /**
   * Approved team-size override (defaults to SiteSettings.maxTeamMembers).
   */
  maxTeamMembersOverride   Int?
  /**
   * Set by administration once flight details are reviewed & finalized.
   */
  flightsFinalizedAt       DateTime?
  /**
   * Host Formation assignment — set by the JLA (Admin) once a travel-ready
   * team is finalized and allotted to the hosting formation.
   */
  hostFormationId          String?
  finalizedForHostAt       DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  unit                     Unit?
  teamMembers              TeamMember[]
  emailVerifications       EmailVerification[]
  passwordResets           PasswordReset[]
  payments                 Payment[]
  auditLogsActed           AuditLog[]          @relation("AuditActor")
  paymentsVerified         Payment[]           @relation("PaymentVerifier")
  supportTickets           SupportTicket[]     @relation("TicketCreator")
  assignedTickets          SupportTicket[]     @relation("TicketAssignee")
  ticketMessages           TicketMessage[]     @relation("TicketMessageAuthor")
  teamSizeRequests         TeamSizeRequest[]   @relation("TeamSizeRequestUser")
  teamSizeReviews          TeamSizeRequest[]   @relation("TeamSizeRequestReviewer")
  flightDetails            FlightDetail[]      @relation("FlightDetailUser")
  hostFormation            HostFormation?      @relation("HostMembers", fields: [hostFormationId], references: [id], onDelete: SetNull)
  hostLoginFor             HostFormation?      @relation("HostLogin")

  @@index([applicationStatus])
  @@index([paymentStatus])
  @@index([approved])
  @@index([hostFormationId])
}

model Unit {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitType             String
  jointPatrol          Boolean  @default(false)
  branch               String
  unitName             String
  bdeOrFmn             String
  divOrFmn             String
  arm                  String
  service              String
  unitAddress          String
  postcode             String
  telephoneMil         String
  telephoneCiv         String
  secondPocEmail       String?
  thirdPocEmail        String?
  additionalInfo       String?  @db.Text
  coName               String
  coEmail              String
  coPhone              String
  coRank               String
  coSalutations        String?
  preferredPhase       String?
  patrolsRequested     Int      @default(1)
  canAccommodateIntl   Boolean  @default(false)
  preferredIntlPatrol  String?
  longStandingRelation Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([unitName])
}

/// Hosting organization (e.g. "HQ 37 Div") created by the JLA (Admin). One
/// dedicated `host`-role login account runs its read-only dashboard; finalized
/// teams are allotted to it via User.hostFormationId.
model HostFormation {
  id         String   @id @default(cuid())
  name       String
  notes      String?  @db.Text
  /**
   * The single `host`-role login account for this formation. Deleting the
   * account cascades to the formation; members detach via SetNull.
   */
  hostUserId String   @unique
  hostUser   User     @relation("HostLogin", fields: [hostUserId], references: [id], onDelete: Cascade)
  members    User[]   @relation("HostMembers")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hostUserId])
}

model TeamMember {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  serviceNumber String
  rank          String        @default("")
  serviceArm    String        @default("")
  gender        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  flightDetail  FlightDetail?

  @@index([userId])
}

/// Participant request to exceed the team-member cap; decided by Admin.
model TeamSizeRequest {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation("TeamSizeRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  requestedCount Int
  justification  String    @db.Text
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote     String?   @db.Text
  reviewedById   String?
  reviewedBy     User?     @relation("TeamSizeRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

/// Per-traveler flight information with passport / ticket PDF attachments.
model FlightDetail {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation("FlightDetailUser", fields: [userId], references: [id], onDelete: Cascade)
  /**
   * The traveller this record belongs to — one FlightDetail per TeamMember.
   * Stays nullable so legacy team-level rows survive; they are adopted by
   * re-linking. Removing a roster member removes their flight record (the
   * roster delete route unlinks the stored PDFs after the DB commit).
   */
  teamMemberId       String?     @unique
  teamMember         TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  passengerName      String
  passportNumber     String
  passportFilePath   String?     @unique
  passportFileName   String?
  passportFileSize   Int?
  passportUploadedAt DateTime?
  ticketFilePath     String?     @unique
  ticketFileName     String?
  ticketFileSize     Int?
  ticketUploadedAt   DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([userId])
}

model Payment {
  id                    String                    @id @default(cuid())
  userId                String
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                Decimal                   @db.Decimal(10, 2)
  currency              String                    @default("PKR")
  status                String                    @default("PENDING")
  proofFileName         String?
  proofMimeType         String?
  internalFilePath      String?                   @unique
  proofOriginalFileName String?
  proofFileSize         Int?
  proofUploadedAt       DateTime?
  uploaderName          String?
  uploaderEmail         String?
  paymentDate           DateTime?
  transactionReference  String?
  adminNotes            String?                   @db.Text
  rejectionReason       String?                   @db.Text
  verifiedById          String?
  verifiedBy            User?                     @relation("PaymentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt            DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  rejectionHistory      PaymentRejectionHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PaymentRejectionHistory {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type      String
  reason    String   @db.Text
  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([createdAt])
}

model SupportTicket {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  category     String          @default("GENERAL")
  status       String          @default("OPEN")
  priority     String          @default("NORMAL")
  assignedToId String?
  assignedTo   User?           @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  lastReplyAt  DateTime        @default(now())
  closedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  messages     TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([assignedToId])
  @@index([lastReplyAt])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?         @relation("TicketMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorRole String        @default("user")
  authorName String
  body       String        @db.Text
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model NewsPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String   @db.Text
  published       Boolean  @default(true)
  publishedAt     DateTime @default(now())
  pdfPath         String?
  pdfOriginalName String?
  pdfMimeType     String?
  pdfFileSize     Int?
  /**
   * Optional announcement/cover image (served from /uploads/news).
   */
  imagePath       String?
  imageMimeType   String?
  imageFileSize   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Competition event catalogue (dynamic, admin-managed; seeded from CONTOUR_EVENTS).
model Event {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  marks             Int      @default(0)
  /**
   * Lucide icon name (resolved client-side; fallback Target).
   */
  icon              String   @default("Target")
  category          String
  difficulty        String
  duration          String
  summary           String   @db.Text
  details           String   @db.Text
  participants      String?
  /**
   * Ordered [{ label, marks }] marks breakdown.
   */
  breakdown         Json?
  /**
   * Optional admin-uploaded card thumbnail (served from /uploads/events).
   */
  thumbnailPath     String?
  thumbnailMimeType String?
  thumbnailFileSize Int?
  sortOrder         Int      @default(0)
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([published, sortOrder])
}

model GalleryImage {
  id            String   @id @default(cuid())
  title         String
  caption       String?  @db.Text
  year          Int?
  category      String?
  /**
   * Discriminator: "image" | "video". Existing rows predate video support and
   * default to "image" so the migration is additive.
   */
  mediaType     String   @default("image")
  /**
   * The media binary — a still for mediaType "image", the video file for "video".
   * Field names kept as-is to avoid a rename migration on live data.
   */
  imagePath     String
  imageMimeType String
  imageFileSize Int
  /**
   * Poster frame for video items (served from /uploads/gallery). Null for stills,
   * and optional for video — the grid falls back to a generic play tile.
   */
  posterPath     String?
  posterMimeType String?
  posterFileSize Int?
  sortOrder     Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, sortOrder])
}

/// Home hero carousel slides (admin-managed; served from /uploads/hero).
model HeroSlide {
  id            String   @id @default(cuid())
  /// Internal label shown in the admin list; never rendered on the public hero.
  title         String
  /// Decorative alt text. The hero images are aria-hidden, so this is admin-facing.
  alt           String?
  imagePath     String
  imageMimeType String
  imageFileSize Int
  sortOrder     Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, sortOrder])
}

/// Exercise results roll — one row per participating patrol/unit.
model Award {
  id        String   @id @default(cuid())
  /// Patrol call sign, e.g. "G12B".
  callSign  String
  unit      String
  /// GOLD | SILVER | BRONZE | COIN | DNF
  medal     String
  /// Exercise year the result belongs to; groups the roll on the public page.
  year      Int
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, year, sortOrder])
}

model KeyDate {
  id        String    @id @default(cuid())
  label     String
  value     String    @db.Text
  date      DateTime?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// Per-locale translations of admin-entered content.
///
/// English lives on the source model itself (`Event.title`, `NewsPost.content`,
/// …); this table holds only the ru/tr/ar/zh renderings that an admin types in
/// the admin forms. A missing row is not an error — the reader falls back to the
/// English source, so untranslated content still renders (just in English).
///
/// Deliberately polymorphic rather than per-locale columns on four models:
/// Event alone would need 16 extra columns, and adding a translatable field
/// would mean a migration every time. The trade-off is no FK/cascade, so rows
/// are cleaned up explicitly when the source record is deleted.
///
/// NOTE: admin content is written at RUNTIME, so it can never be translated at
/// build time, and a static lookup (see `key-date-i18n.ts`) can only cover
/// values known in advance. Automatic machine translation was ruled out by the
/// "no external API calls from the server" constraint — hence manual entry.
model Translation {
  id         String   @id @default(cuid())
  /// Prisma model name: "Event" | "NewsPost" | "GalleryImage" | "KeyDate".
  model      String   @db.VarChar(32)
  /// Primary key (cuid) of the row being translated.
  recordId   String   @db.VarChar(64)
  /// Target locale. Never "en" — English is the source, stored on the model.
  locale     String   @db.VarChar(8)
  /// Field name on the source model, e.g. "title" | "summary" | "caption".
  field      String   @db.VarChar(64)
  value      String   @db.Text
  /// SHA-256 of the English source at the time this translation was saved, so
  /// the admin UI can flag a translation as stale once the English text changes.
  sourceHash String?  @db.VarChar(64)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([model, recordId, locale, field])
  @@index([model, recordId, locale])
}

model TickerAnnouncement {
  id         String    @id @default(cuid())
  message    String    @db.Text
  shortLabel String?
  priority   String    @default("NORMAL")
  status     String    @default("DRAFT")
  visibility String    @default("HOMEPAGE")
  isUrgent   Boolean   @default(false)
  sortOrder  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([visibility])
  @@index([expiresAt])
}

model DataEntryPeriod {
  id        String   @id @default(cuid())
  openDate  DateTime
  label     String
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String?   @unique
  used      Boolean   @default(false)
  tokenHash String?   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SiteSettings {
  id                           String    @id @default("singleton")
  registrationOpen             Boolean   @default(true)
  intlRegistrationOpen         Boolean   @default(true)
  registrationDeadline         DateTime?
  paymentDeadline              DateTime?
  /**
   * Deadline for the first-login participation confirmation dialog.
   */
  participationConfirmDeadline DateTime?
  /**
   * Team registration window (participants may register only inside it).
   */
  teamRegistrationOpenDate     DateTime?
  teamRegistrationCloseDate    DateTime?
  /**
   * Flight details editable until this deadline (or admin finalization).
   */
  flightDetailsDeadline        DateTime?
  /**
   * Default team-member cap (per-user override on User).
   */
  maxTeamMembers               Int       @default(13)
  /**
   * Host information visibility + content for finalized participants.
   */
  hostInfoPublished            Boolean   @default(false)
  hostInfoContent              String?   @db.Text
  exerciseYear                 Int       @default(2026)
  exerciseDates                String    @default("2 – 13 October 2026")
  privacyPolicyUrl             String    @default("/privacy")
  feeNoticeText                String    @db.Text
  approvalNoticeText           String    @db.Text
  facebookUrl                  String    @default("#")
  twitterUrl                   String    @default("#")
  instagramUrl                 String    @default("#")
  merchandiseQrUrl             String    @default("https://www.theprintsofwales.co.uk/cambrian-patrol/")
  photographyQrUrl             String    @default("mailto:igphoto@yahoo.co.uk")
  defaultPaymentAmount         Decimal   @default(15000.00) @db.Decimal(10, 2)
  paymentCurrency              String    @default("PKR")
  paymentBankName              String    @default("HBL")
  paymentBankAccountTitle      String    @default("PATS")
  paymentBankAccountNumber     String    @default("1234567890")
  paymentBankIban              String    @default("PK00HABB0000000012345678")
  paymentEasypaisaNumber       String    @default("0312-3456789")
  paymentEasypaisaTitle        String    @default("PATS")
  paymentJazzcashNumber        String    @default("0300-9876543")
  paymentJazzcashTitle         String    @default("PATS")
  paymentWiseEmail             String    @default("payments@pats.gov.pk")
  paymentWiseName              String    @default("PATS Organising Committee")
  paymentMobileNumber          String    @default("+92 300 1234567")
  paymentMobileTitle           String    @default("PATS")
  paymentRemitlyEmail          String    @default("payments@pats.gov.pk")
  paymentRemitlyName           String    @default("PATS Organising Committee")
  /**
   * SLOW | NORMAL | FAST | VERY_FAST — homepage announcement ticker scroll
   */
  tickerScrollSpeed            String    @default("NORMAL")
}
