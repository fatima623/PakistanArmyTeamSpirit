# Copy this file to `.env` for local development.

# Required
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/pats_db"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-secret-for-backwards-compatibility"

# Optional but recommended for canonical URLs in generated links
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional seed overrides
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_PLAIN="replace-with-a-strong-password"

# Optional email delivery for verification / password reset
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="noreply@example.com"

# Optional storage overrides
PAYMENT_PROOF_STORAGE_DIR="uploads/payment-proofs"
NEWS_PDF_STORAGE_DIR="storage/news-pdfs"

# Optional: local LibreTranslate engine to AUTO-translate admin CMS content
# (ticker messages, announcements) into ru/tr/ar/zh on save. Runs on-server,
# offline; leave unset to keep translations manual. See scripts/backfill-translations.mts.
# AUTO_TRANSLATE_URL=http://127.0.0.1:5000
